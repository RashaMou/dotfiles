[user]
	name = Rasha Moumneh
  email = rasha@fastmailteam.com

[color]
    ui = true

[color "branch"]
    current = yellow reverse
    local = yellow
    remote = green

[color "diff"]
    meta = yellow bold
    frag = magenta bold
    old = red bold
    new = green bold

[color "status"]
    added = yellow
    changed = green
    untracked = red

[push]
	default = current

[core]
	excludesfile = /Users/rasha/.gitignore_global
  editor = nvim

[init]
	defaultBranch = main

[delta]
    line-numbers = true
    side-by-side = false
    commit-decoration-style = bold yellow box ul
    file-style = bold yellow ul
    hunk-headder-decoration-style = pink box

[alias]
	br = branch
	st = status
	cob = checkout -b
	del = branch
	checkpoint = add -A && git commit -m 'chore: commit save point'
  gitbox = pull gitbox master
  co = checkout
  hist = log --graph --oneline
  ir = rebase -i --fork-point master
  logfile = log --oneline --name-only
  shove = push --force-with-lease
  commend = commit --amend --no-edit

[submodule]
  recurse = true

[safe]
  directory = /Users/rasha/fm-box

[pull]
	rebase = true
