[user]
	name = Rasha Moumneh
  email = rasha@fastmailteam.com
[github]
	user = RashaMou
	token = token
[color]
    ui = true

[color "branch"]
    current = yellow reverse
    local = yellow
    remote = green

[color "diff"]
    meta = yellow bold
    frag = magenta bold
    old = red bold
    new = green bold

[color "status"]
    added = yellow
    changed = green
    untracked = red
[push]
	default = current
[core]
	excludesfile = /Users/rasha/.gitignore
[init]
	defaultBranch = main
[pager]
    diff = delta
    log = delta
    reflog = delta
    show = delta
[interactive]
    diffFilter = delta --color-only --features=interactive
[delta]
    line-numbers = true
    side-by-side = false
    commit-decoration-style = bold yellow box ul
    file-style = bold yellow ul
    hunk-headder-decoration-style = pink box
[alias]
	br = branch
	st = status
	cob = checkout -b
	del = branch
	checkpoint = add -A && git commit -m 'chore: commit save point'
  gitbox = pull gitbox master
  co = checkout
  hist = log --graph --oneline
  ir = rebase -i --fork-point master
  logfile = log --oneline --name-only
  shove = push --force-with-lease
  commend = commit --amend --no-edit
[submodule]
  recurse = true
[safe]
  directory = /Users/rasha/fm-box
[pull]
	rebase = true
